# Copy to .env and fill only the provider you want to use.
# Do not commit .env or real API keys.

# Default converter mode is deterministic and does not require AI.
# Set JTC_AI_PROVIDER to enable future AI-assisted restructuring.
# Supported values: openai, anthropic, google, openai-compatible, ollama, lmstudio, local
JTC_AI_PROVIDER=openai-compatible

# Generic provider settings. These work for OpenAI-compatible hosted or local gateways.
JTC_AI_API_KEY=
JTC_AI_BASE_URL=http://127.0.0.1:11434/v1
JTC_AI_MODEL=qwen2.5-coder:7b

# Provider-specific alternatives. Leave blank unless using that provider.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-flash

OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_COMPATIBLE_MODEL=qwen2.5-coder:7b
